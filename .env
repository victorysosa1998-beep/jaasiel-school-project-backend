# ═══════════════════════════════════════════════════════════════
# JAASIEL EDUCATION CENTRE — AI Result Management System
# Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# SQLite (default, no setup needed — great for getting started)
DATABASE_URL=sqlite:///./jaasiel_rms.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/jaasiel_rms

# ── Security ──────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production-must-be-32-chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ── AI / Claude (Anthropic) ───────────────────────────────────
# Used for OCR score extraction from uploaded result sheet images
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── AI / OpenAI (no longer used — kept for reference only) ────
# OPENAI_API_KEY=

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ── School Info (used in report cards & settings defaults) ────
SCHOOL_NAME=Jaasiel Education Centre
SCHOOL_ADDRESS=Oxygen Street, Benin City, Edo State
SCHOOL_PHONE=+234 703 630 4408
SCHOOL_EMAIL=admin@jaasiel.edu.ng
SCHOOL_MOTTO=Accurate Knowledge is a Virtue
PRINCIPAL_NAME=The Principal